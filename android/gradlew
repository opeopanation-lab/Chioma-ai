##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh does
#       not find it, but you have some other *nix shell, you may try invoking the
#       script with that shell.
#   (2) Upstream is careful to set the umask before executing this script,
#       so if you are using umask in your .bashrc/.zshrc, you may need to clear
#       this before running .
#       In particular, `umask 077` eliminates all permissions for the group and
#       other, which will cause this script to fail if run in a Git pre-commit hook
#       awk will be invoked as follows:
#
#           awk 'BEGIN { split("-Xmx1024M", a, / /); for (i in a) print a[i]; }'
#
#       which is why this example ends up preferring the " *" pattern to the " ?
#       pattern.
#
#       10.) (As a corollary of the above) Coprocesses will inherit the environment
#       of the shell from which the script is invoked.  Thus, it is generally best
#       to set the umask in your .bashrc/.zshrc and then invoke the gradlew script
#       from there.
#
##############################################################################

if [ "$(uname)" = "Darwin" ] ; then
    APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) && APP_HOME="${APP_HOME%/}"
else
    APP_HOME=$( cd "${APP_HOME:-./}" 2>/dev/null || echo "$PWD" )
fi

export APP_HOME

appargs=()
while [ $# -gt 0 ] ; do
    case $1 in
        -X* )  appargs+=( "$1" )
               shift
               ;;
        *    )  break
               ;;
    esac
done

exec "$JAVACMD" "${appargs[@]}" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
